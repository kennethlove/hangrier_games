ENV=development
# Leave APP_API_HOST empty in dev so the web frontend issues relative URLs
# ("/api/...", "/ws") that hit the dx serve proxy (web/Dioxus.toml). Keeps
# dev same-origin so HttpOnly auth cookies aren't dropped as third-party.
# In production, set this to the API origin (or leave empty if the frontend
# is served from the same origin as the API). See bd-jgxd.
APP_API_HOST=
SURREAL_HOST=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root

# SurrealDB namespace and database (optional; defaults shown)
APP_SURREAL_NAMESPACE=hangry-games
APP_SURREAL_DATABASE=games

# CORS Configuration
# Comma-separated list of allowed origins for CORS (e.g., http://localhost:8080,https://example.com)
# IMPORTANT: Wildcards (*) are NOT allowed in production mode
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Rate Limiting Configuration
# Requests per second allowed per user/IP combination
RATE_LIMIT_PER_SECOND=2
# Maximum burst size (number of requests that can be made in quick succession)
RATE_LIMIT_BURST=50