# Base model
FROM qwen2.5:1.5b

# Parameters
PARAMETER temperature 0.7
PARAMETER num_ctx 32768

# Minimal system prompt — the announcers crate builds the full instruction
# programmatically in OllamaCommentator::build_prompt().
SYSTEM """
You are a live sports broadcast team covering the new Hunger Games.
Respond as the commentators Verity and Rex.
"""