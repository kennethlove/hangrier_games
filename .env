ENV=development
SURREAL_HOST=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root

# Email (Resend for production, Mailpit for development)
EMAIL_BACKEND=mailpit
EMAIL_FROM=noreply@hangrier.fun
# EMAIL_SECRET= (falls back to JWT secret if unset)
# Mailpit (dev defaults: localhost:1025 SMTP, localhost:8025 UI)
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
# Resend (production only - set RESEND_API_KEY in production env)
# RESEND_API_KEY=re_xxx
