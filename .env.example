ENV=development
APP_API_HOST=http://127.0.0.1:3000
SURREAL_HOST=ws://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root

# CORS Configuration
# Comma-separated list of allowed origins for CORS (e.g., http://localhost:8080,https://example.com)
# IMPORTANT: Wildcards (*) are NOT allowed in production mode
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Rate Limiting Configuration
# Requests per second allowed per user/IP combination
RATE_LIMIT_PER_SECOND=2
# Maximum burst size (number of requests that can be made in quick succession)
RATE_LIMIT_BURST=50